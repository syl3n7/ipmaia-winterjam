# Local testing environment variables
# Copy this to .env.local and adjust as needed
# (docker-compose.local.yml reads this file automatically if named .env)

# Database
DB_NAME=winterjam
DB_USER=postgres
DB_PASSWORD=postgres

# Secrets — change these if you care about session security locally
JWT_SECRET=local-dev-jwt-secret-change-me
SESSION_SECRET=local-dev-session-secret-change-me

# OIDC (optional — leave blank to skip SSO login)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/oidc/callback
OIDC_ADMIN_EMAIL=

# PocketID (optional)
POCKETID_API_URL=
POCKETID_API_KEY=
